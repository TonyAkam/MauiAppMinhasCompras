<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.RelatorioPage"
             Title="Relatório">

	<CollectionView x:Name="ListaRelatorio">
		<CollectionView.ItemTemplate>
			<DataTemplate>
				<Frame Margin="10">
					<StackLayout>
						<Label Text="{Binding Categoria}" FontAttributes="Bold"/>
						<Label Text="{Binding Total, StringFormat='Total: R$ {0:F2}'}"/>
					</StackLayout>
				</Frame>
			</DataTemplate>
		</CollectionView.ItemTemplate>
	</CollectionView>

</ContentPage>